{
    "cell": {
        "path": "xyz_files/cell_BTDPP_In_2mol.xyz"
    },

    "molecules": [{
        "name": "BTDPP",
        "path": "xyz_files/BTDPP.xyz",
        "n_copies": 2
    }],

    "random_seed": 4,

    "n_cycles": 40,
    "stages": [
        {
            "name": "scatter",
            "n_loops": 100,
            "n_trials": 8,
            "params": {
                "dv1": 2,
                "dv2": 2,
                "dphi_e3": 0
            },
            "bind": {
                "DTDPP": ["rotate_e3"]
            }
        },
        {
            "name": "planar",
            "n_loops": 500,
            "n_trials": 8,
            "params": {
                "dv1": 1,
                "dv2": 1,
                "dphi_e3": 1
            },
            "bind": {
                "DTDPP": ["rotate_e3"]
            }
        },
        {
                    "name": "planar",
                    "n_loops": 500,
                    "n_trials": 8,
                    "params": {
                        "dv1": 0.1,
                        "dv2": 0.1,
                        "dphi_e3": 0.1
                    },
                    "bind": {
                        "DTDPP": ["rotate_e3"]
                    }

                }

    ],

    "results_folder_name": "results_btdpp/",
    "results": {
        ".xyz": {
            "cycle_min_periodic": true,
            "cycle_min_cell": true,
            "stages_min_periodic": true,
            "stages_min_cell": true,
            "all_min_periodic": false,
            "all_min_cell": false
        },
        ".txt": {
            "cycle_min": true,
            "stages_min": true,
            "all_min": true
        }
    }

}
