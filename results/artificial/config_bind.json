{
    "unit_cell": {
        "path": "xyz_files/cell.xyz"
    },

    "molecule_list": {
        "path": "xyz_files/mol_list.xyz",
        "molecules": [{
            "name": "DTDPP",
            "n_copies": 3
        }, {
            "name": "DPDPP",
            "n_copies": 2
        }]
    },

    "random_seed": 1,
    "n_cycles": 2,
    "scatter": {
        "n_trials": 32,
        "translate_2D": true,
        "translate_e3": false,
        "rotate_e3": true,
        "rotate_3D": false,
        "deform": false
    },
    "stages": [{
        "name": "planar",
        "n_loops": 100,
        "n_trials": 4,
        "params": {
            "translate_2D": 0.25,
            "rotate_e3": 0.25
        },
        "bind": {
            "DTDPP": ["translate_2D", "rotate_e3"],
            "DPDPP": ["translate_2D", "rotate_e3"]
        }
    }, {
        "name": "settle_into_place",
        "n_loops": 50,
        "n_trials": 8,
        "params": {
            "translate_2D": 0.1,
            "rotate_e3": 0.1,
            "translate_e3": 0.1,
            "rotate_3D": 0.1
        },
        "bind": {
            "DTDPP": ["translate_2D", "rotate_e3", "translate_e3", "rotate_3D"],
            "DPDPP": ["translate_2D", "rotate_e3", "translate_e3", "rotate_3D"]
        }
    }],
    "results": {
        "folder": "results_bind/",
        ".xyz": {
            "cycle_min_periodic": true,
            "cycle_min_cell": true,
            "stages_min_periodic": true,
            "stages_min_cell": true,
            "all_min_periodic": true,
            "all_min_cell": true
        },
        ".txt": {
            "cycle_min": true,
            "stages_min": true,
            "all_min": true
        }
    }

}